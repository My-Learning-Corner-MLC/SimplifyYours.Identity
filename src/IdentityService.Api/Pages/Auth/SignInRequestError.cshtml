@page "/auth/sign-in/request-error"
@model IdentityService.Api.Pages.Auth.SignInRequestErrorModel
@{
    Layout = "/Pages/Shared/_AuthLayout.cshtml";
}

<main class="auth-page d-flex align-items-center py-5">
    <div class="container">
        <div class="row justify-content-center">
            <div class="col-12 col-sm-10 col-md-8 col-lg-5">
                <section class="auth-card bg-white shadow-sm">
                    <div class="p-4 p-sm-5">
                        <h1 class="h3 mb-2">Sign in</h1>
                        <p class="text-body-secondary mb-4">Continue to Simplify Yours</p>
                        <div class="alert alert-warning mb-0" role="alert">
                            @Model.Message
                        </div>
                    </div>
                </section>
            </div>
        </div>
    </div>
</main>
